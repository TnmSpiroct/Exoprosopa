# < Campaign Objectives Region >
newgrounds.welcome = [cyan]Welcome to [blue]Exoprosopa[].\n\nYour mission is to conquer the planet and fight against the Astral Infection.\n\n[accent]Good luck!
newgrounds.move = [cyan]Press [accent][WASD][] or [accent]Drag[] the screen to move the core unit.\n[accent]Scroll[] or [accent]Pinch[] the screen to zoom in and out.\n\[accent]Left Click[] or [accent]Tap[] on [#647cc2]cobalt[] ore to mine it.
newgrounds.mining = [cyan]Mine [#647cc2]Cobalt[] from the wall.\nThis resource is used in many buildings. 
newgrounds.generator = [cyan]Research the [accent]Pressure Generator[] from the \ue875 tech tree.\n\nPlace it on the vent to generate \ue810 power.
newgrounds.extractor = [cyan]Research the [accent]Ore Extractor[] from the \ue875 tech tree.\n\nPlace the [accent]Ore Extractor[] facing directly to [#647cc2]cobalt[] wall.
newgrounds.elixir = [cyan]Research the [accent]Elixir Collector[] from the \ue875 tech tree.\n\nPlace it on the vent to extract [#d488ea]Elixir[].
newgrounds.powerline = [cyan]Research and place 3 [accent]Powerlines[] to distribute power\nto other blocks orthogonally.
newgrounds.cobalt = [cyan]Transport the mined [#647cc2]Cobalt[] into the core with [accent]Transport Pipes[].
newgrounds.conduit = [cyan]Supply the [accent]Ore Extractor[] with [#d488ea]Elixir[] from the [accent]Elixir Collector[] with [accent]Sea Conduit[].
newgrounds.pipe = [cyan]Connect the [accent]Ore Extractor[] to your core\nby placing several [accent]Transport Pipes[].
newgrounds.nickel = [#e1cf9a]Nickel[cyan] is required for most factories in Exoprosopa.\n\nExpand the mining area.
newgrounds.vent = [cyan]Place more [accent]Elixir Collectors[]\nto operate more [accent]Ore Extractors[].
newgrounds.furnace = [cyan]Research the [accent]Aluminium Furnace[]\n\nThis factory requires [#647cc2]Cobalt[], Anthracite, and [accent]power[]\nto produce [#729aaf]Aluminium[].\n\n\ue804 Move up a bit to mine [accent]Anthracite[].
newgrounds.aluminium = [cyan]Expand the production chain.\nCollect [accent]250 Aluminium[] to build a [accent]Unit Factory[].
newgrounds.anthracite = [accent]Anthracite[cyan] functions as a fuel for [accent]Aluminium Furnaces[cyan]\nThe core [red]wont accept [cyan]anthracite as a material.
newgrounds.shipbay = [cyan]Research the [accent]Shipbay[] from the \ue875 tech tree.\n\nFullfill the requirements to produce your first unit.
newgrounds.codex = [cyan]Produce Unit: Spark\n\nShipbay Requirements:\n[#e1cf9a]Nickel[], [#729aaf]Aluminium[], [#d488ea] Elixir[], and [accent]Power[].
newgrounds.command = [cyan]Command Units:\n\nUse [accent]Shift + Left Click[] or press [accent]Command Mode[] button to select a unit, drag to select multiple units.\nThen [accent]Shift + Right Click[] or [accent]Tap[] to a random location to move the selected unit to a location.\n\nControl Units:\n\nUse [accent]Ctrl + Left Click[] or [accent]Tap[] the unit twice to control a unit.\nPress [accent][V][] or [accent]Tap[] the unit icon on the health bar to respawn.\nYou can also control the [accent]Turrets[] and especially the [accent]Router[].
newgrounds.impale = [cyan]Open the \ue875 tech tree and research [accent]Impale[]\nSupply the turret with [#647cc2]Cobalt[] or [#729aaf]Aluminium[] as ammunition.\n\nThis turret fires a piercing bullet towards enemies.
newgrounds.wall = [cyan]Research [accent]Cobalt Wall[] from the tech tree \ue875\nto protect your structures from enemy projectiles.
newgrounds.enemy = [cyan]Claim this sector by capturing the [accent]enemy core[].\n[red]The enemy is vulnerable now, launch a counterattack!

attack.timer = [red]Prepare for an enemy attack!
objective.warn = [red]Warning !!!
objective.news = [accent]Reinforcements\nhas arrived !!!
objective.t1 = [accent]Enemy Tier 1 Production starting in [lightgray]{0}
objective.t2 = [accent]Enemy Tier 2 Production starting in [lightgray]{0}
objective.t3 = [accent]Enemy Tier 3 Production starting in [lightgray]{0}
objective.t4 = [accent]Enemy Tier 4 Production starting in [lightgray]{0}
objective.t5 = [accent]Enemy Tier 5 Production starting in [lightgray]{0}

mountainridge.tantrium = [cyan]This sector is rich in [#90bdd8]Tantrium[]\n\nExtract [#90bdd8]Tantrium[] from tantrium walls using [accent]Tantrium Crushers[].
mountainridge.purify = [cyan]Use the [accent]Elixir Purifier[] to purify the [#d488ea]elixir[]\nby using [#90bdd8]tantrium[] to produce [#76c9e5]Cryogenics[].\n\nThis can be used to cool your turrets and boost [accent]Ore Extractors[].

luminary.burnergenerator = [cyan]Vents are a good source of power, but they are limited.\nSet up [accent]Burner Generators[] to produce extra power for production and defense.

sealedoutpost.borejet = [cyan]This sector has a lot of anthracite and cobalt in the ground.\nResearch the [accent]Bore Jet[] from the \ue875 tech tree to mine resources from the ground.

foggyfields.guardian = [cyan]The enemy will send a backup force after 8 minutes.\nCapture this sector before the guardian arrives.

reservoir.miasma = [cyan]This sector is filled with [#b979bd]miasma[].\nIts very reactive to [#d488ea]elixir[], keep your factory safe from it.

crest.mech = [cyan]This sector is filled with rough terrain.\nUse [accent]Mech[] units to attack the enemy base.

cliffside.borejet = [cyan]Place a [accent]Bore Jet[] on [#9d7f7f]Chromium[] ore to start mining,\nExpand your factory and defense using chromium tech.
cliffside.chromium = [cyan]This sector contains deposits of [#9d7f7f]Chromium[].\n[accent]Bore Jets[] are required to mine this resource.

bgard.sdriver = [cyan]Research [accent]Surge Driver[cyan] from the \ue875 tech tree.\nPlace two [accent]Surge Drivers[] in the designated locations.\n\nSet up the [accent]Surge Driver[] by clicking one of them, then selecting the other one\nto transport resources from the other side of the mountain.
bgard.chromium = [cyan]Collect additional [#9d7f7f]Chromium[] by transporting it via [accent]Surge Drivers[].

cornerstone.mountain = [cyan]The enemy base is protected with strong defences.\nConstruct tier 2 tank units to break through the enemy defences.

escarpment.tantrium = [#90bdd8]Tantrium[cyan] is a very scarce resource in this sector.\n\nResearch and place a [#90bdd8]Tantraformer[cyan] to create [#90bdd8]Tantrium[cyan] utilizing the surrounding environment.

hazardouswasteland.miasma = [cyan]Research [#afe986]Clevorite[] and the [accent]Geothermal Generator[] from the \ue875 tech tree.\nPlace 2 [accent]Geothermal Generators[] and supply them with [#b979bd]Miasma[] and [#76c9e5]Cryogenics[] to generate power.

